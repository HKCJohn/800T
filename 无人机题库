        { text: "焊接作业防护用品不包括？", options: ["护目镜","耐高温手套","高跟鞋","通风设备"], correct: "C" },
        { text: "无人机机架采用空心结构，目的是？", options: ["增加重量","减重同时保证强度","美观","容纳杂物"], correct: "B" },
        { text: "四旋翼X型布局的优势是？", options: ["操控均衡、稳定性强","载重最大","速度最快","成本最低"], correct: "A" },
        { text: "无人机起飞前电机测试，目的是？", options: ["校准电机转向","提升电量","增强信号","清洁电机"], correct: "A" },
        { text: "以下哪项不属于无人机飞行四大基础力？", options: ["升力","重力","磁力","阻力"], correct: "C" },
        { text: "多旋翼无人机最大短板是？", options: ["操控简单","续航普遍偏短","稳定性强","可悬停"], correct: "B" },
        { text: "竞速无人机设计重点是？", options: ["载重","速度与机动性","续航","航拍画质"], correct: "B" },
        { text: "高空长航时（HALE）无人机主要用于？", options: ["室内娱乐","长期高空侦察/监测","农业喷洒","短途航拍"], correct: "B" },
        { text: "无人机电池使用后，正确操作是？", options: ["立即充电","自然冷却后再充电","泡水降温","暴晒降温"], correct: "B" },
        { text: "无人机飞行日志的作用是？", options: ["娱乐查看","故障复盘、数据分析","存储照片","播放视频"], correct: "B" },
        { text: "商用无人机定期维保的目的是？", options: ["应付检查","排查隐患、延长设备寿命","改变外观","升级款式"], correct: "B" }
    ];

    // --------------------------------------------------------------
    // 应用状态
    // --------------------------------------------------------------
    let currentMode = 'fill';     // 'fill' 或 'choice'
    let currentIndex = 0;         // 当前题目索引 (0-based)
    let score = 0;               // 当前模式得分

    // 存储每个题目是否答对 (null=未答, true=正确, false=错误)
    let fillResults = new Array(fillBlankData.length).fill(null);
    let choiceResults = new Array(choiceData.length).fill(null);

    // DOM 元素
    const questionCard = document.getElementById('questionCard');
    const currentNumSpan = document.getElementById('currentNum');
    const totalNumSpan = document.getElementById('totalNum');
    const scoreDisplay = document.getElementById('scoreDisplay');
    const totalScoreNum = document.getElementById('totalScoreNum');

    // --------------------------------------------------------------
    // 核心渲染函数
    // --------------------------------------------------------------
    function render() {
        const data = currentMode === 'fill' ? fillBlankData : choiceData;
        const results = currentMode === 'fill' ? fillResults : choiceResults;
        const total = data.length;

        // 更新进度
        currentNumSpan.textContent = currentIndex + 1;
        totalNumSpan.textContent = total;
        totalScoreNum.textContent = total;

        // 计算得分
        const correctCount = results.filter(r => r === true).length;
        score = correctCount;
        scoreDisplay.textContent = score;

        // 如果已完成所有题目（索引越界）
        if (currentIndex >= total) {
            questionCard.innerHTML = `
                <div class="complete-msg">
                    🎉 恭喜你完成所有 ${currentMode === 'fill' ? '填空' : '选择'} 题目！<br>
                    得分：${score} / ${total}
                </div>
            `;
            return;
        }

        const item = data[currentIndex];
        const isAnswered = results[currentIndex] !== null;
        const isCorrect = results[currentIndex] === true;

        // 构建题目
        let html = '';

        // 题目标题
        const modeName = currentMode === 'fill' ? '填空题' : '选择题';
        html += `<div class="q-header">
                    <span class="q-type">${modeName}</span>
                    <span class="q-number">第 ${currentIndex+1} / ${total} 题</span>
                </div>`;

        // 题目文本
        html += `<div class="q-text">${item.text}</div>`;

        if (currentMode === 'fill') {
            // 填空：将 ______ 替换为输入框
            const parts = item.text.split(/______/g);
            let inputHtml = '';
            for (let i = 0; i < parts.length; i++) {
                inputHtml += parts[i];
                if (i < parts.length - 1) {
                    const disabled = isAnswered ? 'disabled' : '';
                    const value = isAnswered ? (isCorrect ? item.answer : '') : '';
                    inputHtml += `<input type="text" class="blank-input" id="fillInput" ${disabled} value="${value}" placeholder="输入答案">`;
                }
            }
            html += `<div style="margin: 8px 0 12px;">${inputHtml}</div>`;
        } else {
            // 选择题
            const letters = ['A','B','C','D'];
            html += `<div class="options">`;
            item.options.forEach((opt, idx) => {
                const letter = letters[idx];
                const selected = isAnswered && item.correct === letter ? 'selected' : '';
                const disabled = isAnswered ? 'disabled-opt' : '';
                const checked = isAnswered && item.correct === letter ? 'checked' : '';
                html += `<label class="option-label ${disabled} ${selected}" data-opt-val="${letter}">
                            <input type="radio" name="choice" value="${letter}" ${checked} ${isAnswered ? 'disabled' : ''}>
                            <span class="option-letter">${letter}.</span> ${opt}
                        </label>`;
            });
            html += `</div>`;
        }

        // 反馈区域
        let feedbackHtml = '';
        if (isAnswered) {
            if (isCorrect) {
                feedbackHtml = `<div class="feedback-box feedback-correct">✅ 回答正确！</div>`;
            } else {
                const correctAns = currentMode === 'fill' ? item.answer : `${item.correct}. ${item.options[item.correct.charCodeAt(0)-65]}`;
                feedbackHtml = `<div class="feedback-box feedback-wrong">❌ 错误 · 正确答案：${correctAns}</div>`;
            }
        } else {
            feedbackHtml = `<div class="feedback-box feedback-idle">⏳ 请作答后点击「检查答案」</div>`;
        }

        // 导航按钮区域
        const prevDisabled = currentIndex === 0;
        const nextDisabled = !isAnswered || currentIndex === total - 1;
        const checkDisabled = isAnswered || currentMode === 'choice'; // 选择题自动判，填空需要手动检查

        html += `<div class="action-area">
                    <div class="feedback-box" style="flex:2; min-width:150px;">${feedbackHtml}</div>
                    <div class="nav-group">
                        <button class="btn-nav secondary" id="prevBtn" ${prevDisabled ? 'disabled' : ''}>⬅️ 上一题</button>
                        ${currentMode === 'fill' ? `<button class="btn-check" id="checkBtn" ${checkDisabled ? 'disabled' : ''}>🔍 检查答案</button>` : ''}
                        <button class="btn-nav" id="nextBtn" ${nextDisabled ? 'disabled' : ''}>➡️ 下一题</button>
                    </div>
                </div>`;

        questionCard.innerHTML = html;

        // ---------- 事件绑定 ----------
        // 填空题：检查答案按钮
        if (currentMode === 'fill') {
            const checkBtn = document.getElementById('checkBtn');
            const input = document.getElementById('fillInput');
            if (checkBtn && input) {
                checkBtn.addEventListener('click', function() {
                    if (results[currentIndex] !== null) return; // 已答
                    const userVal = input.value.trim();
                    if (userVal === '') {
                        alert('请先输入答案再检查！');
                        return;
                    }
                    const isCorrect = isFillAnswerMatch(userVal, item.answer);
                    results[currentIndex] = isCorrect;
                    // 禁用输入
                    input.disabled = true;
                    // 更新反馈
                    const fbBox = document.querySelector('.feedback-box');
                    if (fbBox) {
                        if (isCorrect) {
                            fbBox.className = 'feedback-box feedback-correct';
                            fbBox.textContent = '✅ 回答正确！';
                        } else {
                            fbBox.className = 'feedback-box feedback-wrong';
                            fbBox.textContent = `❌ 错误 · 正确答案：${item.answer}`;
                        }
                    }
                    // 更新得分
                    const correctCount = results.filter(r => r === true).length;
                    scoreDisplay.textContent = correctCount;
                    // 启用下一题
                    const nextBtn = document.getElementById('nextBtn');
                    if (nextBtn) nextBtn.disabled = false;
                    // 禁用检查按钮
                    this.disabled = true;
                });
            }
        }

        // 选择题：点击选项自动判题
        if (currentMode === 'choice' && !isAnswered) {
            const radios = document.querySelectorAll('input[name="choice"]');
            radios.forEach(radio => {
                radio.addEventListener('change', function() {
                    if (results[currentIndex] !== null) return;
                    const val = this.value;
                    const isCorrect = (val === item.correct);
                    results[currentIndex] = isCorrect;
                    // 禁用所有选项
                    document.querySelectorAll('.option-label').forEach(lb => {
                        lb.classList.add('disabled-opt');
                        lb.querySelector('input').disabled = true;
                    });
                    // 高亮正确答案
                    document.querySelectorAll('.option-label').forEach(lb => {
                        const radioVal = lb.querySelector('input').value;
                        if (radioVal === item.correct) {
                            lb.classList.add('selected');
                        }
                    });
                    // 更新反馈
                    const fbBox = document.querySelector('.feedback-box');
                    if (fbBox) {
                        if (isCorrect) {
                            fbBox.className = 'feedback-box feedback-correct';
                            fbBox.textContent = '✅ 回答正确！';
                        } else {
                            const correctAns = `${item.correct}. ${item.options[item.correct.charCodeAt(0)-65]}`;
                            fbBox.className = 'feedback-box feedback-wrong';
                            fbBox.textContent = `❌ 错误 · 正确答案：${correctAns}`;
                        }
                    }
                    // 更新得分
                    const correctCount = results.filter(r => r === true).length;
                    scoreDisplay.textContent = correctCount;
                    // 启用下一题
                    const nextBtn = document.getElementById('nextBtn');
                    if (nextBtn) nextBtn.disabled = false;
                });
            });
        }

        // 上一题
        const prevBtn = document.getElementById('prevBtn');
        if (prevBtn) {
            prevBtn.addEventListener('click', function() {
                if (currentIndex > 0) {
                    currentIndex--;
                    render();
                }
            });
        }

        // 下一题
        const nextBtn = document.getElementById('nextBtn');
        if (nextBtn) {
            nextBtn.addEventListener('click', function() {
                if (this.disabled) return;
                if (currentIndex < data.length - 1) {
                    currentIndex++;
                    render();
                }
            });
        }

        // 如果已经回答，确保下一题可用
        if (isAnswered) {
            const nextBtn2 = document.getElementById('nextBtn');
            if (nextBtn2) nextBtn2.disabled = (currentIndex === data.length - 1);
        }
    }

    // 辅助：填空答案匹配（与文档一致）
    function isFillAnswerMatch(user, std) {
        let u = user.trim().toLowerCase().replace(/[％%]/g, '').replace(/[，,]/g, ',');
        let s = std.toLowerCase().replace(/[％%]/g, '').replace(/[，,]/g, ',');
        if (u === s) return true;
        if (s.includes('/')) {
            return s.split('/').some(part => part === u);
        }
        if (s === "20%~50%" && /^20%?~50%?$/.test(u)) return true;
        return false;
    }

    // 切换模式
    function switchMode(mode) {
        if (mode === currentMode) return;
        currentMode = mode;
        currentIndex = 0;
        document.querySelectorAll('.mode-btn').forEach(btn => btn.classList.remove('active'));
        document.querySelector(`.mode-btn[data-mode="${mode}"]`).classList.add('active');
        render();
    }

    // 重置当前模式
    function resetCurrentMode() {
        const results = currentMode === 'fill' ? fillResults : choiceResults;
        results.fill(null);
        currentIndex = 0;
        render();
    }

    // 重置全部
    function resetAll() {
        fillResults.fill(null);
        choiceResults.fill(null);
        currentIndex = 0;
        render();
    }

    // --------------------------------------------------------------
    // 初始化事件绑定
    // --------------------------------------------------------------
    document.getElementById('modeFillBtn').addEventListener('click', () => switchMode('fill'));
    document.getElementById('modeChoiceBtn').addEventListener('click', () => switchMode('choice'));
    document.getElementById('resetModeBtn').addEventListener('click', resetCurrentMode);
    document.getElementById('resetAllBtn').addEventListener('click', resetAll);

    // 初次渲染
    render();
</script>
</body>
</html>
