<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>无人机题库 · 逐题闯关（含检查与上一题）</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background: #eef2f5;
            font-family: 'Segoe UI', 'Roboto', 'Helvetica Neue', sans-serif;
            padding: 20px;
            color: #1a2c3e;
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: flex-start;
        }

        .container {
            max-width: 1100px;
            width: 100%;
            background: white;
            border-radius: 40px;
            box-shadow: 0 20px 40px rgba(0,0,0,0.08);
            overflow: hidden;
            padding: 28px 30px 40px;
            margin: 0 auto;
        }

        /* 头部 */
        .header {
            display: flex;
            flex-wrap: wrap;
            justify-content: space-between;
            align-items: center;
            gap: 16px;
            margin-bottom: 30px;
            padding-bottom: 18px;
            border-bottom: 2px solid #e6edf4;
        }

        .header h1 {
            font-size: 1.9rem;
            font-weight: 700;
            color: #0b2b3b;
            letter-spacing: -0.5px;
        }

        .header h1 small {
            font-size: 1rem;
            font-weight: 400;
            color: #4d6b7e;
            margin-left: 12px;
        }

        .mode-tabs {
            display: flex;
            gap: 12px;
            flex-wrap: wrap;
        }

        .mode-btn {
            padding: 10px 28px;
            border-radius: 60px;
            border: 2px solid #cbdbe2;
            background: white;
            font-weight: 600;
            font-size: 1rem;
            cursor: pointer;
            transition: 0.2s;
            color: #1a3b4f;
        }

        .mode-btn.active {
            background: #1a4a6f;
            border-color: #1a4a6f;
            color: white;
            box-shadow: 0 4px 10px rgba(26,74,111,0.2);
        }

        .mode-btn:hover:not(.active) {
            background: #f0f7fc;
            border-color: #8bb3cc;
        }

        /* 进度 & 得分 */
        .progress-area {
            display: flex;
            flex-wrap: wrap;
            justify-content: space-between;
            align-items: center;
            background: #f6f9fc;
            border-radius: 60px;
            padding: 12px 22px;
            margin-bottom: 30px;
        }

        .progress-text {
            font-weight: 500;
            font-size: 1rem;
        }

        .progress-text strong {
            color: #0b2b3b;
            font-size: 1.2rem;
        }

        .score-badge {
            background: #ffcd3c;
            color: #1e2f3e;
            font-weight: bold;
            border-radius: 40px;
            padding: 6px 20px;
            font-size: 1.1rem;
        }

        /* 题目卡片 */
        .question-card {
            background: #fafdff;
            border: 2px solid #e2edf2;
            border-radius: 32px;
            padding: 32px 30px;
            margin-bottom: 24px;
            transition: 0.1s;
            box-shadow: 0 2px 6px rgba(0,0,0,0.02);
        }

        .q-header {
            display: flex;
            align-items: baseline;
            gap: 12px;
            flex-wrap: wrap;
            margin-bottom: 20px;
        }

        .q-type {
            background: #d9e9f0;
            padding: 4px 16px;
            border-radius: 30px;
            font-size: 0.75rem;
            font-weight: 700;
            color: #005073;
            letter-spacing: 0.3px;
        }

        .q-number {
            font-weight: 600;
            color: #1f4c66;
        }

        .q-text {
            font-size: 1.2rem;
            font-weight: 500;
            line-height: 1.6;
            color: #0b2b3b;
            margin-bottom: 20px;
            word-break: break-word;
        }

        /* 填空输入 */
        .blank-input {
            display: inline-block;
            min-width: 200px;
            padding: 10px 18px;
            border: 2px solid #cbdbe2;
            border-radius: 60px;
            font-size: 1rem;
            background: white;
            transition: 0.15s;
            font-family: inherit;
            width: auto;
        }

        .blank-input:focus {
            border-color: #2c7da0;
            outline: none;
            box-shadow: 0 0 0 3px rgba(44,125,160,0.15);
        }

        .blank-input:disabled {
            background: #f2f6f9;
            border-color: #d0dce4;
        }

        /* 选择题选项 */
        .options {
            display: flex;
            flex-direction: column;
            gap: 12px;
            margin: 8px 0 12px;
        }

        .option-label {
            display: flex;
            align-items: center;
            gap: 14px;
            padding: 12px 20px;
            border-radius: 60px;
            border: 2px solid #deeaf0;
            cursor: pointer;
            transition: 0.15s;
            background: white;
            font-size: 1rem;
        }

        .option-label:hover:not(.disabled-opt) {
            background: #f0f7fc;
            border-color: #b5d0dd;
        }

        .option-label.selected {
            background: #e1f0f7;
            border-color: #2c7da0;
            box-shadow: 0 0 0 1px #2c7da0;
        }

        .option-label.disabled-opt {
            cursor: default;
            opacity: 0.8;
        }

        .option-label input[type="radio"] {
            accent-color: #2c7da0;
            width: 20px;
            height: 20px;
            flex-shrink: 0;
        }

        .option-letter {
            font-weight: 700;
            color: #1f4c66;
            min-width: 24px;
        }

        /* 反馈 & 导航按钮 */
        .action-area {
            display: flex;
            flex-wrap: wrap;
            align-items: center;
            justify-content: space-between;
            margin-top: 24px;
            gap: 16px;
        }

        .feedback-box {
            padding: 8px 18px;
            border-radius: 60px;
            font-weight: 500;
            font-size: 0.95rem;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            flex: 1;
            min-width: 180px;
        }

        .feedback-correct {
            background: #e1f7e8;
            color: #1e6f3f;
        }

        .feedback-wrong {
            background: #ffe6e5;
            color: #bc3900;
        }

        .feedback-idle {
            background: #f0f4f8;
            color: #4b6d80;
        }

        .btn-nav {
            background: #1a4a6f;
            border: none;
            padding: 10px 24px;
            border-radius: 60px;
            color: white;
            font-weight: 600;
            font-size: 1rem;
            cursor: pointer;
            transition: 0.2s;
            box-shadow: 0 4px 10px rgba(26,74,111,0.15);
            white-space: nowrap;
        }

        .btn-nav:hover:not(:disabled) {
            background: #0f3857;
            transform: scale(1.02);
        }

        .btn-nav:disabled {
            background: #b7cbd9;
            cursor: not-allowed;
            box-shadow: none;
        }

        .btn-nav.secondary {
            background: #6b8fa8;
        }

        .btn-nav.secondary:hover:not(:disabled) {
            background: #51758e;
        }

        .btn-check {
            background: #ffb347;
            border: none;
            padding: 10px 28px;
            border-radius: 60px;
            font-weight: 600;
            font-size: 1rem;
            color: #1e2f3e;
            cursor: pointer;
            transition: 0.2s;
            box-shadow: 0 4px 10px rgba(255,179,71,0.2);
        }

        .btn-check:hover:not(:disabled) {
            background: #ff9f1c;
            transform: scale(1.02);
        }

        .btn-check:disabled {
            background: #e6d5b0;
            cursor: not-allowed;
            box-shadow: none;
        }

        .btn-reset {
            background: #e1e9f0;
            border: none;
            padding: 10px 22px;
            border-radius: 60px;
            font-weight: 500;
            color: #1a3b4f;
            cursor: pointer;
            transition: 0.2s;
        }

        .btn-reset:hover {
            background: #d0dce6;
        }

        .btn-reset.reset-mode {
            background: #ffb347;
            color: #1e2f3e;
        }

        .btn-reset.reset-mode:hover {
            background: #ff9f1c;
        }

        .footer-actions {
            display: flex;
            gap: 12px;
            flex-wrap: wrap;
            margin-top: 10px;
        }

        .nav-group {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
            align-items: center;
        }

        /* 完成状态 */
        .complete-msg {
            background: #e1f7e8;
            border-radius: 40px;
            padding: 20px 28px;
            text-align: center;
            font-size: 1.2rem;
            font-weight: 600;
            color: #1a5a3a;
        }

        @media (max-width: 700px) {
            .container { padding: 18px 16px; }
            .header h1 { font-size: 1.5rem; }
            .mode-btn { padding: 8px 18px; font-size: 0.9rem; }
            .question-card { padding: 24px 18px; }
            .q-text { font-size: 1rem; }
            .blank-input { min-width: 140px; }
            .action-area { flex-direction: column; align-items: stretch; }
            .btn-nav, .btn-check { width: 100%; text-align: center; }
            .feedback-box { min-width: unset; }
            .nav-group { justify-content: center; }
        }
    </style>
</head>
<body>
<div class="container" id="app">
    <!-- 头部 -->
    <div class="header">
        <h1>✈ 无人机闯关 <small>逐题训练</small></h1>
        <div class="mode-tabs">
            <button class="mode-btn active" data-mode="fill" id="modeFillBtn">📝 填空题</button>
            <button class="mode-btn" data-mode="choice" id="modeChoiceBtn">🔘 选择题</button>
        </div>
    </div>

    <!-- 进度 & 得分 -->
    <div class="progress-area">
        <span class="progress-text">第 <strong id="currentNum">1</strong> / <span id="totalNum">100</span> 题</span>
        <span class="score-badge">🏆 <span id="scoreDisplay">0</span> / <span id="totalScoreNum">100</span></span>
    </div>

    <!-- 题目卡片 -->
    <div id="questionCard" class="question-card">
        <!-- 动态渲染 -->
    </div>

    <!-- 底部操作 -->
    <div class="footer-actions">
        <button class="btn-reset reset-mode" id="resetModeBtn">🔄 重新开始本模式</button>
        <button class="btn-reset" id="resetAllBtn">🗑️ 重置全部进度</button>
    </div>
</div>

<script>
    // --------------------------------------------------------------
    // 题库数据 (完全来自文档)
    // --------------------------------------------------------------
    const fillBlankData = [
        { text: "操作无人机前，首要检查______是否完好、无鼓包、破损，是防范起火的关键。", answer: "锂电池" },
